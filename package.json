{
  "name": "codex-quota-widget",
  "version": "1.2.0",
  "description": "Windows desktop widget for monitoring local Codex quota.",
  "main": "src/main/main.js",
  "author": "Codex Quota Widget Contributors",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "build": "set CSC_IDENTITY_AUTO_DISCOVERY=false&& electron-builder --win portable",
    "build:dir": "set CSC_IDENTITY_AUTO_DISCOVERY=false&& electron-builder --dir",
    "build:mac": "electron-packager . \"Codex Quota Widget\" --platform=darwin --arch=arm64 --out=dist --overwrite --asar --prune=true --app-bundle-id=cn.codex.quota.widget --app-category-type=public.app-category.utilities",
    "test": "node --test"
  },
  "build": {
    "appId": "cn.codex.quota.widget",
    "productName": "Codex Quota Widget",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/icon.*",
      "package.json"
    ],
    "win": {
      "icon": "assets/icon.ico",
      "signExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "Codex-Quota-Widget-${version}-win-x64.exe"
    },
    "mac": {
      "category": "public.app-category.utilities",
      "identity": null,
      "target": [
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "artifactName": "Codex-Quota-Widget-${version}-mac-arm64.${ext}"
    }
  },
  "devDependencies": {
    "@electron/packager": "^20.0.2",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3"
  }
}
